<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Login</title>
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@300;400;600&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet"/>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
 
    :root {
      --bg: #0d0d0d;
      --surface: #161616;
      --border: #2a2a2a;
      --border-focus: #c9a84c;
      --gold: #c9a84c;
      --gold-light: #e8c96a;
      --text: #f0ede6;
      --text-muted: #7a7570;
      --text-subtle: #3d3a36;
      --error: #e05c5c;
      --success: #5cba8a;
      --radius: 6px;
    }
 
    body {
      min-height: 100vh;
      background: var(--bg);
      display: flex;
      align-items: center;
      justify-content: center;
      font-family: 'DM Sans', sans-serif;
      color: var(--text);
      overflow: hidden;
    }
 
    /* Animated background grid */
    body::before {
      content: '';
      position: fixed;
      inset: 0;
      background-image:
        linear-gradient(rgba(201,168,76,0.03) 1px, transparent 1px),
        linear-gradient(90deg, rgba(201,168,76,0.03) 1px, transparent 1px);
      background-size: 60px 60px;
      animation: gridShift 20s linear infinite;
      pointer-events: none;
    }
 
    @keyframes gridShift {
      0% { transform: translate(0, 0); }
      100% { transform: translate(60px, 60px); }
    }
 
    /* Ambient glow */
    body::after {
      content: '';
      position: fixed;
      width: 600px;
      height: 600px;
      background: radial-gradient(circle, rgba(201,168,76,0.06) 0%, transparent 70%);
      top: 50%;
      left: 50%;
      transform: translate(-50%, -50%);
      pointer-events: none;
    }
 
    .card {
      position: relative;
      width: 420px;
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 2px;
      padding: 52px 48px 48px;
      animation: cardIn 0.7s cubic-bezier(0.16, 1, 0.3, 1) both;
      z-index: 1;
    }
 
    @keyframes cardIn {
      from { opacity: 0; transform: translateY(24px); }
      to   { opacity: 1; transform: translateY(0); }
    }
 
    /* Gold corner accent */
    .card::before {
      content: '';
      position: absolute;
      top: 0; left: 0;
      width: 40px; height: 40px;
      border-top: 1px solid var(--gold);
      border-left: 1px solid var(--gold);
    }
    .card::after {
      content: '';
      position: absolute;
      bottom: 0; right: 0;
      width: 40px; height: 40px;
      border-bottom: 1px solid var(--gold);
      border-right: 1px solid var(--gold);
    }
 
    .brand {
      display: flex;
      align-items: center;
      gap: 10px;
      margin-bottom: 36px;
      animation: fadeUp 0.6s 0.15s cubic-bezier(0.16, 1, 0.3, 1) both;
    }
 
    .brand-mark {
      width: 28px;
      height: 28px;
      border: 1.5px solid var(--gold);
      position: relative;
      display: flex;
      align-items: center;
      justify-content: center;
    }
 
    .brand-mark::before {
      content: '';
      width: 10px;
      height: 10px;
      background: var(--gold);
    }
 
    .brand-name {
      font-family: 'Cormorant Garamond', serif;
      font-size: 18px;
      font-weight: 400;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      color: var(--gold);
    }
 
    .heading {
      font-family: 'Cormorant Garamond', serif;
      font-size: 38px;
      font-weight: 300;
      letter-spacing: -0.01em;
      line-height: 1.1;
      color: var(--text);
      margin-bottom: 8px;
      animation: fadeUp 0.6s 0.2s cubic-bezier(0.16, 1, 0.3, 1) both;
    }
 
    .subheading {
      font-size: 13px;
      font-weight: 300;
      color: var(--text-muted);
      letter-spacing: 0.01em;
      margin-bottom: 36px;
      animation: fadeUp 0.6s 0.25s cubic-bezier(0.16, 1, 0.3, 1) both;
    }
 
    @keyframes fadeUp {
      from { opacity: 0; transform: translateY(12px); }
      to   { opacity: 1; transform: translateY(0); }
    }
 
    .field {
      margin-bottom: 20px;
      animation: fadeUp 0.6s cubic-bezier(0.16, 1, 0.3, 1) both;
    }
    .field:nth-of-type(1) { animation-delay: 0.3s; }
    .field:nth-of-type(2) { animation-delay: 0.35s; }
 
    .label {
      display: block;
      font-size: 11px;
      font-weight: 500;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--text-muted);
      margin-bottom: 8px;
      transition: color 0.2s;
    }
 
    .input-wrap {
      position: relative;
    }
 
    input[type="email"],
    input[type="password"],
    input[type="text"] {
      width: 100%;
      background: #0d0d0d;
      border: 1px solid var(--border);
      border-radius: var(--radius);
      padding: 13px 16px;
      font-family: 'DM Sans', sans-serif;
      font-size: 14px;
      font-weight: 300;
      color: var(--text);
      outline: none;
      transition: border-color 0.25s, box-shadow 0.25s;
      -webkit-appearance: none;
    }
 
    input:focus {
      border-color: var(--gold);
      box-shadow: 0 0 0 3px rgba(201,168,76,0.08);
    }
 
    input.error {
      border-color: var(--error);
      box-shadow: 0 0 0 3px rgba(224,92,92,0.08);
    }
 
    input.valid {
      border-color: var(--success);
    }
 
    input::placeholder { color: var(--text-subtle); }
 
    .toggle-pw {
      position: absolute;
      right: 14px;
      top: 50%;
      transform: translateY(-50%);
      background: none;
      border: none;
      cursor: pointer;
      color: var(--text-muted);
      padding: 2px;
      display: flex;
      align-items: center;
      transition: color 0.2s;
    }
    .toggle-pw:hover { color: var(--gold); }
 
    .field-error {
      font-size: 11px;
      color: var(--error);
      margin-top: 6px;
      height: 0;
      overflow: hidden;
      transition: height 0.2s;
      opacity: 0;
      transition: opacity 0.2s, height 0.2s;
    }
    .field-error.show {
      height: 16px;
      opacity: 1;
    }
 
    .field-label-row {
      display: flex;
      justify-content: space-between;
      align-items: baseline;
      margin-bottom: 8px;
    }
 
    .forgot {
      font-size: 11px;
      color: var(--text-muted);
      text-decoration: none;
      letter-spacing: 0.05em;
      transition: color 0.2s;
    }
    .forgot:hover { color: var(--gold); }
 
    .options {
      display: flex;
      align-items: center;
      justify-content: space-between;
      margin: 24px 0 28px;
      animation: fadeUp 0.6s 0.4s cubic-bezier(0.16, 1, 0.3, 1) both;
    }
 
    .remember {
      display: flex;
      align-items: center;
      gap: 8px;
      cursor: pointer;
      font-size: 13px;
      font-weight: 300;
      color: var(--text-muted);
    }
 
    .remember input[type="checkbox"] { display: none; }
 
    .checkbox-box {
      width: 16px;
      height: 16px;
      border: 1px solid var(--border);
      border-radius: 3px;
      background: #0d0d0d;
      display: flex;
      align-items: center;
      justify-content: center;
      transition: border-color 0.2s, background 0.2s;
      flex-shrink: 0;
    }
 
    .remember:hover .checkbox-box { border-color: var(--gold); }
 
    .remember input:checked ~ .checkbox-box {
      background: var(--gold);
      border-color: var(--gold);
    }
 
    .check-icon {
      display: none;
      width: 9px;
      height: 9px;
    }
    .remember input:checked ~ .checkbox-box .check-icon { display: block; }
 
    .btn-login {
      width: 100%;
      padding: 14px;
      background: var(--gold);
      border: none;
      border-radius: var(--radius);
      font-family: 'DM Sans', sans-serif;
      font-size: 13px;
      font-weight: 500;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: #0d0d0d;
      cursor: pointer;
      transition: background 0.2s, transform 0.15s, box-shadow 0.2s;
      position: relative;
      overflow: hidden;
      animation: fadeUp 0.6s 0.45s cubic-bezier(0.16, 1, 0.3, 1) both;
    }
 
    .btn-login:hover {
      background: var(--gold-light);
      box-shadow: 0 4px 20px rgba(201,168,76,0.25);
    }
 
    .btn-login:active { transform: scale(0.98); }
 
    .btn-login:disabled {
      opacity: 0.5;
      cursor: not-allowed;
      transform: none;
    }
 
    .btn-login .spinner {
      display: none;
      width: 16px;
      height: 16px;
      border: 2px solid rgba(0,0,0,0.2);
      border-top-color: #0d0d0d;
      border-radius: 50%;
      animation: spin 0.6s linear infinite;
      position: absolute;
      top: 50%;
      left: 50%;
      transform: translate(-50%, -50%);
    }
 
    @keyframes spin {
      to { transform: translate(-50%, -50%) rotate(360deg); }
    }
 
    .btn-login.loading .btn-text { visibility: hidden; }
    .btn-login.loading .spinner { display: block; }
 
    .divider {
      display: flex;
      align-items: center;
      gap: 12px;
      margin: 28px 0;
      animation: fadeUp 0.6s 0.5s cubic-bezier(0.16, 1, 0.3, 1) both;
    }
 
    .divider::before, .divider::after {
      content: '';
      flex: 1;
      height: 1px;
      background: var(--border);
    }
 
    .divider span {
      font-size: 11px;
      letter-spacing: 0.1em;
      color: var(--text-subtle);
      text-transform: uppercase;
    }
 
    .social-btns {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 10px;
      animation: fadeUp 0.6s 0.55s cubic-bezier(0.16, 1, 0.3, 1) both;
    }
 
    .btn-social {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 8px;
      padding: 11px;
      background: transparent;
      border: 1px solid var(--border);
      border-radius: var(--radius);
      font-family: 'DM Sans', sans-serif;
      font-size: 13px;
      font-weight: 400;
      color: var(--text-muted);
      cursor: pointer;
      transition: border-color 0.2s, color 0.2s, background 0.2s;
    }
 
    .btn-social:hover {
      border-color: var(--gold);
      color: var(--text);
      background: rgba(201,168,76,0.04);
    }
 
    .signup-row {
      text-align: center;
      margin-top: 28px;
      font-size: 12px;
      font-weight: 300;
      color: var(--text-muted);
      animation: fadeUp 0.6s 0.6s cubic-bezier(0.16, 1, 0.3, 1) both;
    }
 
    .signup-row a {
      color: var(--gold);
      text-decoration: none;
      font-weight: 400;
    }
    .signup-row a:hover { text-decoration: underline; }
 
    /* Success state */
    .success-msg {
      display: none;
      text-align: center;
      padding: 20px 0;
    }
 
    .success-msg.show { display: block; }
 
    .success-icon {
      width: 52px;
      height: 52px;
      border: 1.5px solid var(--success);
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      margin: 0 auto 16px;
      animation: popIn 0.4s cubic-bezier(0.16, 1, 0.3, 1);
    }
 
    @keyframes popIn {
      from { opacity: 0; transform: scale(0.7); }
      to   { opacity: 1; transform: scale(1); }
    }
 
    .success-text {
      font-family: 'Cormorant Garamond', serif;
      font-size: 22px;
      font-weight: 300;
      color: var(--text);
      margin-bottom: 6px;
    }
 
    .success-sub {
      font-size: 13px;
      color: var(--text-muted);
    }
  </style>
</head>
<body>
  <div class="card" role="main">
    <div class="brand">
      <div class="brand-mark"></div>
      <span class="brand-name">Aurum</span>
    </div>
 
    <div id="form-section">
      <h1 class="heading">Welcome<br/>back.</h1>
      <p class="subheading">Sign in to continue to your account.</p>
 
      <form id="loginForm" novalidate>
        <div class="field" id="field-email">
          <label class="label" for="email">Email address</label>
          <div class="input-wrap">
            <input type="email" id="email" placeholder="you@example.com" autocomplete="email"/>
          </div>
          <p class="field-error" id="email-error">Please enter a valid email address.</p>
        </div>
 
        <div class="field" id="field-password">
          <div class="field-label-row">
            <label class="label" for="password" style="margin-bottom:0">Password</label>
            <a href="#" class="forgot">Forgot?</a>
          </div>
          <div class="input-wrap">
            <input type="password" id="password" placeholder="••••••••" autocomplete="current-password" style="padding-right: 44px;"/>
            <button type="button" class="toggle-pw" id="togglePw" aria-label="Toggle password visibility">
              <svg id="eye-icon" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
                <path d="M2 12s3.5-7 10-7 10 7 10 7-3.5 7-10 7S2 12 2 12z"/>
                <circle cx="12" cy="12" r="3"/>
              </svg>
              <svg id="eye-off-icon" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24" style="display:none">
                <path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94"/>
                <path d="M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19"/>
                <line x1="1" y1="1" x2="23" y2="23"/>
              </svg>
            </button>
          </div>
          <p class="field-error" id="pw-error">Password must be at least 8 characters.</p>
        </div>
 
        <div class="options">
          <label class="remember">
            <input type="checkbox" id="remember"/>
            <div class="checkbox-box">
              <svg class="check-icon" viewBox="0 0 9 9" fill="none" stroke="#0d0d0d" stroke-width="1.5">
                <polyline points="1,5 3.5,7.5 8,2"/>
              </svg>
            </div>
            Remember me
          </label>
        </div>
 
        <button type="submit" class="btn-login" id="loginBtn">
          <span class="btn-text">Sign In</span>
          <div class="spinner"></div>
        </button>
 
        <div class="divider"><span>or continue with</span></div>
 
        <div class="social-btns">
          <button type="button" class="btn-social">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/><path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/><path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" fill="#FBBC05"/><path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/></svg>
            Google
          </button>
          <button type="button" class="btn-social">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0 1 12 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"/></svg>
            GitHub
          </button>
        </div>
 
        <p class="signup-row">Don't have an account? <a href="#">Create one</a></p>
      </form>
    </div>
 
    <div class="success-msg" id="successMsg">
      <div class="success-icon">
        <svg width="22" height="22" fill="none" stroke="#5cba8a" stroke-width="1.5" viewBox="0 0 24 24">
          <polyline points="20,6 9,17 4,12"/>
        </svg>
      </div>
      <p class="success-text">You're in.</p>
      <p class="success-sub">Redirecting to your dashboard…</p>
    </div>
  </div>
 
  <script>
    const emailInput = document.getElementById('email');
    const pwInput    = document.getElementById('password');
    const form       = document.getElementById('loginForm');
    const loginBtn   = document.getElementById('loginBtn');
    const togglePw   = document.getElementById('togglePw');
    const eyeIcon    = document.getElementById('eye-icon');
    const eyeOffIcon = document.getElementById('eye-off-icon');
 
    togglePw.addEventListener('click', () => {
      const isHidden = pwInput.type === 'password';
      pwInput.type   = isHidden ? 'text' : 'password';
      eyeIcon.style.display    = isHidden ? 'none'  : 'block';
      eyeOffIcon.style.display = isHidden ? 'block' : 'none';
    });
 
    function setError(input, errorId, show) {
      const err = document.getElementById(errorId);
      if (show) {
        input.classList.add('error');
        input.classList.remove('valid');
        err.classList.add('show');
      } else {
        input.classList.remove('error');
        input.classList.add('valid');
        err.classList.remove('show');
      }
    }
 
    function validateEmail() {
      const val = emailInput.value.trim();
      const ok  = /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(val);
      if (val) setError(emailInput, 'email-error', !ok);
      return ok;
    }
 
    function validatePw() {
      const ok = pwInput.value.length >= 8;
      if (pwInput.value) setError(pwInput, 'pw-error', !ok);
      return ok;
    }
 
    emailInput.addEventListener('blur', validateEmail);
    pwInput.addEventListener('blur', validatePw);
    emailInput.addEventListener('input', () => emailInput.classList.contains('error') && validateEmail());
    pwInput.addEventListener('input',    () => pwInput.classList.contains('error')    && validatePw());
 
    form.addEventListener('submit', e => {
      e.preventDefault();
      const emailOk = validateEmail();
      const pwOk    = validatePw();
      if (!emailOk || !pwOk) return;
 
      loginBtn.classList.add('loading');
      loginBtn.disabled = true;
 
      setTimeout(() => {
        document.getElementById('form-section').style.display = 'none';
        document.getElementById('successMsg').classList.add('show');
      }, 1800);
    });
  </script>
</body>
</html>
