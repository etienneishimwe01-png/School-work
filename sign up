<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Sign Up Form</title>
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;500&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">
  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body { background: #f5f5f2; min-height: 100vh; display: flex; align-items: center; justify-content: center; }

    .wrap { max-width: 480px; width: 100%; margin: 0 auto; padding: 2.5rem 1rem 3rem; }
    .eyebrow { font-family: 'DM Sans', sans-serif; font-size: 11px; font-weight: 500; letter-spacing: 0.18em; text-transform: uppercase; color: #888; margin-bottom: 0.75rem; }
    h1 { font-family: 'Playfair Display', serif; font-size: 32px; font-weight: 400; color: #1a1a1a; line-height: 1.2; margin-bottom: 0.4rem; }
    .sub { font-family: 'DM Sans', sans-serif; font-size: 14px; color: #888; font-weight: 300; margin-bottom: 2rem; }

    .row { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; }
    .field { margin-bottom: 1rem; }
    label { display: block; font-family: 'DM Sans', sans-serif; font-size: 12px; font-weight: 500; letter-spacing: 0.06em; text-transform: uppercase; color: #888; margin-bottom: 6px; }

    input[type=text],
    input[type=email],
    input[type=password] {
      width: 100%; padding: 11px 14px;
      font-family: 'DM Sans', sans-serif; font-size: 14px; font-weight: 400;
      color: #1a1a1a; background: #fff;
      border: 0.5px solid #ccc; border-radius: 6px;
      outline: none; transition: border-color 0.15s;
    }
    input:focus { border-color: #999; box-shadow: 0 0 0 3px rgba(0,0,0,0.04); }

    .pw-wrap { position: relative; }
    .pw-wrap input { padding-right: 42px; }
    .pw-toggle {
      position: absolute; right: 12px; top: 50%; transform: translateY(-50%);
      background: none; border: none; cursor: pointer; color: #888;
      font-size: 12px; font-family: 'DM Sans', sans-serif; font-weight: 500;
      letter-spacing: 0.04em; padding: 4px;
    }

    .divider { display: flex; align-items: center; gap: 12px; margin: 1.25rem 0; }
    .divider::before, .divider::after { content: ''; flex: 1; height: 0.5px; background: #ddd; }
    .divider span { font-family: 'DM Sans', sans-serif; font-size: 12px; color: #aaa; white-space: nowrap; }

    .btn-primary {
      width: 100%; padding: 13px;
      font-family: 'DM Sans', sans-serif; font-size: 14px; font-weight: 500;
      letter-spacing: 0.04em; color: #fff; background: #1a1a1a;
      border: none; border-radius: 6px; cursor: pointer;
      transition: opacity 0.15s; margin-top: 0.25rem;
    }
    .btn-primary:hover { opacity: 0.85; }
    .btn-primary:active { transform: scale(0.99); }

    .btn-google {
      width: 100%; padding: 11px;
      font-family: 'DM Sans', sans-serif; font-size: 14px; font-weight: 400;
      color: #1a1a1a; background: #fff;
      border: 0.5px solid #ccc; border-radius: 6px; cursor: pointer;
      display: flex; align-items: center; justify-content: center; gap: 10px;
      transition: background 0.15s;
    }
    .btn-google:hover { background: #f5f5f2; }
    .google-icon { width: 16px; height: 16px; flex-shrink: 0; }

    .strength { display: flex; gap: 4px; margin-top: 6px; }
    .bar { flex: 1; height: 2px; border-radius: 2px; background: #e0e0e0; transition: background 0.3s; }
    .bar.weak   { background: #E24B4A; }
    .bar.fair   { background: #EF9F27; }
    .bar.good   { background: #639922; }
    .bar.strong { background: #1D9E75; }

    .terms { font-family: 'DM Sans', sans-serif; font-size: 12px; color: #aaa; text-align: center; margin-top: 1.25rem; line-height: 1.6; }
    .terms a { color: #888; text-decoration: underline; text-underline-offset: 2px; cursor: pointer; }
    .signin { font-family: 'DM Sans', sans-serif; font-size: 13px; color: #888; text-align: center; margin-top: 1.5rem; }
    .signin a { color: #1a1a1a; font-weight: 500; text-decoration: none; cursor: pointer; }
  </style>
</head>
<body>
  <div class="wrap">
    <p class="eyebrow">Get started</p>
    <h1>Create your account</h1>
    <p class="sub">Join thousands already using our platform.</p>

    <!-- Google OAuth Button -->
    <button class="btn-google" onclick="this.textContent='Connecting…'">
      <svg class="google-icon" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
        <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/>
        <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
        <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l3.66-2.84z" fill="#FBBC05"/>
        <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/>
      </svg>
      Continue with Google
    </button>

    <div class="divider"><span>or sign up with email</span></div>

    <!-- Name Fields -->
    <div class="row">
      <div class="field">
        <label>First name</label>
        <input type="text" placeholder="Jane" autocomplete="given-name">
      </div>
      <div class="field">
        <label>Last name</label>
        <input type="text" placeholder="Smith" autocomplete="family-name">
      </div>
    </div>

    <!-- Email -->
    <div class="field">
      <label>Email address</label>
      <input type="email" placeholder="jane@example.com" autocomplete="email">
    </div>

    <!-- Password with toggle & strength meter -->
    <div class="field">
      <label>Password</label>
      <div class="pw-wrap">
        <input type="password" id="pw" placeholder="Min. 8 characters"
               oninput="updateStrength(this.value)" autocomplete="new-password">
        <button class="pw-toggle" onclick="togglePw()" id="tog">Show</button>
      </div>
      <div class="strength" id="bars">
        <div class="bar" id="b1"></div>
        <div class="bar" id="b2"></div>
        <div class="bar" id="b3"></div>
        <div class="bar" id="b4"></div>
      </div>
    </div>

    <button class="btn-primary">Create account</button>

    <p class="terms">
      By creating an account, you agree to our
      <a>Terms of Service</a> and <a>Privacy Policy</a>.
    </p>
    <p class="signin">Already have an account? <a>Sign in</a></p>
  </div>

  <script>
    function togglePw() {
      const pw = document.getElementById('pw');
      const tog = document.getElementById('tog');
      if (pw.type === 'password') {
        pw.type = 'text';
        tog.textContent = 'Hide';
      } else {
        pw.type = 'password';
        tog.textContent = 'Show';
      }
    }

    function updateStrength(v) {
      const bars = [
        document.getElementById('b1'),
        document.getElementById('b2'),
        document.getElementById('b3'),
        document.getElementById('b4')
      ];
      bars.forEach(b => { b.className = 'bar'; });
      if (!v) return;

      let score = 0;
      if (v.length >= 8)           score++;  // length check
      if (/[A-Z]/.test(v))         score++;  // uppercase
      if (/[0-9]/.test(v))         score++;  // number
      if (/[^A-Za-z0-9]/.test(v)) score++;  // special char

      const cls = ['', 'weak', 'fair', 'good', 'strong'];
      for (let i = 0; i < score; i++) {
        bars[i].classList.add(cls[score]);
      }
    }
  </script>
</body>
</html>
